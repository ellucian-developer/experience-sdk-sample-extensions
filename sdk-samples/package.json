    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "babel-jest": "29.7.0",
    "babel-plugin-rewire": "1.2.0",
    "cross-env": "7.0.2",
    "dotenv": "8.2.0",
    "eslint": "9.33.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.0.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
